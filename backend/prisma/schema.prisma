generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  role      String     @default("usuario")
  favorites Favorite[]
  carts     Cart[]
}

model Refeicao {
  id           String   @id @default(uuid())
  name         String
  valor        String
  sobre        String
  image        String
  ingredientes String[]

  cartItems CartItem[]
  favorites Favorite[]
}

model Sobremesa {
  id           String   @id @default(uuid())
  name         String
  valor        String
  sobre        String
  image        String
  ingredientes String[]

  cartItems CartItem[]
  favorites Favorite[]
}

model Bebida {
  id           String   @id @default(uuid())
  name         String
  valor        String
  sobre        String
  image        String
  ingredientes String[]

  cartItems CartItem[]
  favorites Favorite[]
}

model Cart {
  id     String     @id @default(uuid())
  user   User       @relation(fields: [userId], references: [id])
  userId String
  items  CartItem[]
}

model CartItem {
  id          String     @id @default(uuid())
  cart        Cart       @relation(fields: [cartId], references: [id])
  cartId      String
  refeicao    Refeicao?  @relation(fields: [refeicaoId], references: [id])
  refeicaoId  String?
  sobremesa   Sobremesa? @relation(fields: [sobremesaId], references: [id])
  sobremesaId String?
  bebida      Bebida?    @relation(fields: [bebidaId], references: [id])
  bebidaId    String?
  quantity    Int
}

model Favorite {
  id          String     @id @default(uuid())
  user        User       @relation(fields: [userId], references: [id])
  userId      String
  refeicao    Refeicao?  @relation(fields: [refeicaoId], references: [id])
  refeicaoId  String?
  sobremesa   Sobremesa? @relation(fields: [sobremesaId], references: [id])
  sobremesaId String?
  bebida      Bebida?    @relation(fields: [bebidaId], references: [id])
  bebidaId    String?

  @@unique([userId, refeicaoId, sobremesaId, bebidaId])
}
